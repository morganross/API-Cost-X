# APICostX local self-host configuration
# Copy this file to .env and fill in values for your own machine.
# All secrets for the self-hosted app live in this one root .env file.

API_COST_X_MODE=local
API_COST_X_HOST=127.0.0.1
API_COST_X_API_PORT=8000
API_COST_X_WEB_PORT=5173
API_COST_X_DATA_DIR=./data
API_COST_X_DATABASE_URL=sqlite+aiosqlite:///./data/api-cost-x.db
API_COST_X_LOGS_DIR=./logs

# Optional explicit data subdirectories. By default these live under API_COST_X_DATA_DIR.
# API_COST_X_DOCUMENTS_DIR=./data/documents
# API_COST_X_ARTIFACTS_DIR=./data/artifacts

# WARNING: setting API_COST_X_HOST to anything other than localhost/127.0.0.1/::1 exposes APICostX on the network.
# Only uncomment this for a deliberately secured deployment with firewall/TLS/access controls in place.
# API_COST_X_ALLOW_UNSAFE_BIND=1

VITE_API_BASE_URL=http://127.0.0.1:8000/api

# Provider keys for local runs. Uncomment and fill only what you use.
# OPENAI_API_KEY=
# ANTHROPIC_API_KEY=
# GOOGLE_API_KEY=
# OPENROUTER_API_KEY=
# GROQ_API_KEY=
# PERPLEXITY_API_KEY=
# TAVILY_API_KEY=
# NVIDIA_API_KEY=

# Optional GitHub token for GitHub import/export features.
# GITHUB_TOKEN=
